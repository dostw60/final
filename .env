# .env
# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nepse_data
DB_USER=nepse_user
DB_PASSWORD=secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API
API_PORT=3000
API_KEY=your_secret_api_key_here

# Scraping
SCRAPE_RATE_LIMIT_MS=1000
MAX_RETRIES=3
RETRY_DELAY_MS=2000
REQUEST_TIMEOUT_MS=10000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# NEPSE Sources
MEROLAGANI_API_URL=https://www.merolagani.com/Handlers/GetMarketOverviewHandler.ashx
NEPSE_ALPHA_API=https://nepsealpha.com/api
SHARESANSAR_API=https://www.sharesansar.com/api

# Environment
NODE_ENV=production
TIMEZONE=Asia/Kathmandu